# ==========================================
# CS2 KOOK Bot - 环境变量配置模板
# 使用说明：请将此文件复制并重命名为 .env，然后填入你的真实数据
# ⚠️ 警告：绝对不要把填了真实密码的 .env 文件上传到公开仓库！
# ==========================================

# KOOK 机器人 Token (必填，在 KOOK 开发者控制台获取)
BOT_TOKEN=

# Steam 开发者 API 密钥 (必填，用于查询 CS2 战绩与服务器状态)
STEAM_API_KEY=

# 允许使用刷屏/高频指令 (如 /open, /status 等) 的 KOOK 频道 ID (必填)
ALLOWED_CHANNEL_ID=

# ==========================================
# 云端数据持久化配置 (依赖 Hugging Face)
# 说明：如果不配置，机器人仍可运行，但每次重启会丢失经济局数据和本地缓存
# ==========================================

# Hugging Face Access Token (需具备 Write 权限)
HF_TOKEN=

# 云端数据集仓库地址 (格式: 用户名/仓库名，例如 username/Bot_Data)
HF_REPO_ID=
